# oxwrt secrets overlay — example.
#
# Lives at `/etc/oxwrt/oxwrt.secrets.toml` on the router, mode 0600.
# Loaded AFTER the public `oxwrt.toml`; leaves here win on conflict.
# Entries are matched to the public file by identity key:
#   [[wifi]]               → ssid
#   [[wireguard.peers]]    → name (nested inside its [[wireguard]])
#   [[ddns]]               → name
#   [[networks]]           → name  (only for mode="pppoe" passwords)
#
# Non-secret fields may also appear here — useful for overriding a
# single value via CI — but the canonical shape is "just the secret
# leaf plus whatever identity is needed to locate its parent entry."
#
# `oxctl dump-config` shows the merged view with every secret
# replaced by `<redacted>`, so you can verify the overlay is picked
# up without ever echoing the raw credential.
#
# Note: crypto identity seeds (sQUIC signing key, WG server key,
# VPN client keys, DHCPv6 DUID) are NOT here and NOT in oxwrt.toml.
# They live as separate files under /etc/oxwrt/, auto-generated
# (or provider-staged for VPN) on first boot. See the "Cryptographic
# identity vs. configuration" block at the top of oxwrt.toml.

# ── WiFi passphrases ──
# Paired by ssid with the [[wifi]] entries in oxwrt.toml.

[[wifi]]
ssid = "oxwrt"
passphrase = "replace-with-a-real-passphrase-8-plus-chars"

[[wifi]]
ssid = "oxwrt-2g"
passphrase = "replace-with-a-real-passphrase-8-plus-chars"

# ── WireGuard peer PSKs ──
# Uncomment to add forward secrecy on a roadwarrior peer.
# Nested under the matching [[wireguard]] by name:
#
# [[wireguard]]
# name = "wg0"
#
# [[wireguard.peers]]
# name = "laptop"
# preshared_key = "base64-32-bytes-here"

# ── DDNS credentials ──
# One of `token` / `api_token` / `password` / `key` depending on
# the provider variant you chose in the public file.
#
# [[ddns]]
# name = "home-duck"
# token = "your-duckdns-account-token"
#
# [[ddns]]
# name = "home-cf"
# api_token = "cloudflare-Zone.DNS-Edit-token"
#
# [[ddns]]
# name = "home-nc"
# password = "per-host-ddns-key-from-namecheap-dashboard"
#
# [[ddns]]
# name = "home-dynv6"
# token = "per-zone-dynv6-token"
#
# [[ddns]]
# name = "home-he"
# key = "ddns-key-from-he.net-dns-dashboard"

# ── PPPoE password ──
# Pairs by name with a [[networks]] entry whose mode = "pppoe".
#
# [[networks]]
# name = "wan"
# password = "isp-supplied-pppoe-pw"
