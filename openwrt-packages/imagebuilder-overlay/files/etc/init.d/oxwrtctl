#!/bin/sh /etc/rc.common
#
# procd init script for oxwrtctl running as a side binary on a stock
# OpenWrt system. Starts in --control-only mode: only the sQUIC control
# plane runs; no mounts, no netlink, no firewall, no supervisor. Safe to
# leave enabled alongside procd/netifd/fw4 on an unmodified OpenWrt image.
#
# Operator workflow: `ssh root@<router> /etc/init.d/oxwrtctl {start,stop,
# restart,enable,disable}`. `enable` plumbs it into procd's boot sequence
# so the control plane comes up on every reboot.
#
# When the firmware eventually takes over as PID 1 this script becomes
# redundant and will be dropped from the imagebuilder overlay in favor
# of the /sbin/init symlink path in openwrt-packages/oxwrtctl/Makefile.

USE_PROCD=1

# Start late — after network + firewall are up. The control plane
# binds to 192.168.1.1:51820 which requires the LAN bridge to be
# addressed, so we can't start earlier than the network stack.
START=95
STOP=01

PROG=/usr/bin/oxwrtctl

start_service() {
    # Refuse to start if the binary is missing — gives a clearer
    # failure than procd's generic "respawn too fast" loop.
    [ -x "$PROG" ] || {
        echo "oxwrtctl: $PROG not found or not executable" >&2
        return 1
    }

    procd_open_instance oxwrtctl
    procd_set_param command "$PROG" --control-only
    # Respawn on crash: threshold=3600s, timeout=5s, retry=5 times before
    # giving up. Matches procd defaults for long-running daemons.
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/oxwrtctl.pid
    # No file descriptors inherited — oxwrtctl opens its own sockets.
    procd_set_param limits nofile=16384
    procd_close_instance
}

reload_service() {
    # oxwrtctl's own `reload` RPC handles config reparsing in-band.
    # A procd-level reload = restart (simpler, guaranteed fresh state).
    stop
    start
}
