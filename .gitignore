/target/
/build/
/openwrt/
# OpenWrt imagebuilder scratch dir — tarball + extracted tree are multi-GB
# downloads regenerated on demand; the tracked overlay lives under
# `openwrt-packages/imagebuilder-overlay/`.
/imagebuilder/
# Staged cross-built service binaries (hickory-dns, ntp-daemon, coredhcp)
# produced by `make services-stage`. Size: tens of MBs; regenerate on demand.
/build-services/
.idea/
*.swp
*.swo
*~
.DS_Store
# Per-device provisioning secrets: 32-byte ed25519 seed baked into
# images as /etc/oxwrt/key.ed25519. Must never be committed — it IS
# the server identity.
/provisioning/
# Operator env: SQUIC_SERVER_KEY (the pubkey pinned by oxctl).
.env
