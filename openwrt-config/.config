# oxwrt OpenWRT configuration.
#
# Target: MediaTek Filogic / GL.iNet GL-MT6000 (Flint 2).
# MT7986 (Filogic 830), quad-core A53 @ 2GHz, 1GB DDR4.
# Mainline kernel (6.12, bump to 7.0 when ready).
# Fully open: mt76 WiFi driver, HNAT offload, no proprietary blobs.
#
# This is a STRIPPED config — no procd, netifd, dnsmasq, dropbear, etc.
# All userspace is replaced by oxwrtd (Rust PID 1).

# ── Target ───────────────────────────────────────────────────────────
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt6000=y

# ── Image format ─────────────────────────────────────────────────────
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

# ── Kernel ───────────────────────────────────────────────────────────
# nftables kernel modules (required by rustables firewall install)
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y
# CONFIG_PACKAGE_kmod-nf-ipt is not set

# mt76 WiFi driver (WiFi 6, open-source, mainline)
CONFIG_PACKAGE_kmod-mt7915e=y

# MediaTek HNAT hardware offload (open-source, mainline)
# Enables wire-speed 2.5GbE forwarding via mtk_ppe_offload.
CONFIG_PACKAGE_kmod-mediatek_hnat=y

# cgroup v2 (required by oxwrtd container supervisor)
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_PIDS=y
CONFIG_KERNEL_MEMCG=y
CONFIG_KERNEL_NAMESPACES=y
CONFIG_KERNEL_USER_NS=y
CONFIG_KERNEL_PID_NS=y
CONFIG_KERNEL_NET_NS=y

# Landlock LSM (required by oxwrtd hardening layer)
# Available on kernel 6.12+ (mainline). All 5 hardening layers active.
CONFIG_KERNEL_SECURITY_LANDLOCK=y

# dm-verity (block-level rootfs integrity, plan §6 three-layer story)
CONFIG_KERNEL_DM_VERITY=y
CONFIG_KERNEL_DM_INIT=y
CONFIG_KERNEL_BLK_DEV_DM=y

# seccomp-bpf
CONFIG_KERNEL_SECCOMP=y
CONFIG_KERNEL_SECCOMP_FILTER=y

# ── Strip default packages ───────────────────────────────────────────
# Disable ALL standard OpenWRT userspace. oxwrtd replaces everything.
CONFIG_PACKAGE_procd=n
CONFIG_PACKAGE_procd-ujail=n
CONFIG_PACKAGE_procd-seccomp=n
CONFIG_PACKAGE_busybox=n
CONFIG_PACKAGE_netifd=n
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=n
CONFIG_PACKAGE_odhcpd-ipv6only=n
CONFIG_PACKAGE_odhcp6c=n
CONFIG_PACKAGE_dropbear=n
CONFIG_PACKAGE_firewall4=n
CONFIG_PACKAGE_nftables=n
CONFIG_PACKAGE_uci=n
CONFIG_PACKAGE_libubox=n
CONFIG_PACKAGE_ubus=n
CONFIG_PACKAGE_ubusd=n
CONFIG_PACKAGE_logd=n
CONFIG_PACKAGE_rpcd=n
CONFIG_PACKAGE_opkg=n
CONFIG_PACKAGE_fstools=n
CONFIG_PACKAGE_urandom-seed=n
CONFIG_PACKAGE_urngd=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_ppp=n
CONFIG_PACKAGE_ppp-mod-pppoe=n
CONFIG_PACKAGE_kmod-ppp=n

# ── Our packages ─────────────────────────────────────────────────────
CONFIG_PACKAGE_oxwrtd=y
CONFIG_PACKAGE_oxwrt-dns=y
CONFIG_PACKAGE_oxwrt-dhcp=y
CONFIG_PACKAGE_oxwrt-ntp=y
CONFIG_PACKAGE_oxwrt-diag=y

# ── Build options ────────────────────────────────────────────────────
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_BUILD_LOG=y
