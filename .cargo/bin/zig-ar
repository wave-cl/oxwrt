#!/bin/sh
# Cross-compilation `ar` wrapper used by cargo-zigbuild when producing
# Linux-musl static archives. `zig ar` in Zig 0.14+ refuses `cq`/`rcs`
# on first-time archive creation, so ring's build script fails. GNU
# `ar` (binutils) handles it correctly.
#
# - macOS: Apple's /usr/bin/ar doesn't write thin archives in the
#   format ring expects; need the binutils build installed via brew
#   / macports.
# - Linux (incl. GitHub Actions ubuntu-latest): /usr/bin/ar IS GNU ar,
#   use it directly.
case "$(uname -s)" in
  Darwin)
    for cand in \
        /opt/homebrew/opt/binutils/bin/ar \
        /usr/local/opt/binutils/bin/ar \
        /Users/c/homebrew/opt/binutils/bin/ar \
        /opt/local/bin/gar; do
        if [ -x "$cand" ]; then exec "$cand" "$@"; fi
    done
    echo "zig-ar: GNU binutils ar not found. brew install binutils." >&2
    exit 127
    ;;
  *)
    if [ -x /usr/bin/ar ]; then
        exec /usr/bin/ar "$@"
    fi
    exec ar "$@"
    ;;
esac
